# Ignore ENV file.
.env

# Virtual environments.
.venv/
venv/
env/

# Temporary test virtual environments.
.tmp-test-venv/

# Python bytecode / caches.
__pycache__/
*$py.class

# "*.py[cod]"" covers "*.pyc" too.
*.py[cod]

.pytest_cache/
.mypy_cache/

# Ignore Python linting cache.
.ruff_cache/

# Python packaging/build artifacts
build/
dist/
*.egg-info/
src/*.egg-info/

# ANTLR4 output directory where all output is generated to.
gen-output

# Ignore .antlr dir itself and all its contents.
**/.antlr/**

# Coverage.
.coverage
htmlcov/
coverage.xml

# Ignore logs...
logs
*.log

*.local
