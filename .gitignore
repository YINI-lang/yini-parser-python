# Ignore ENV file.
.env

# Python bytecode / caches.
__pycache__/
*$py.class

# "*.py[cod]"" covers "*.pyc" too.
*.py[cod]

.pytest_cache/
.mypy_cache/

# Ignore Python linting cache.
.ruff_cache/

# Python packaging/build artifacts
build/
dist/
*.egg-info/
src/*.egg-info/

# DO NOT ignore js files in examples.
!examples/basic-output.js
!examples/nested-output.js

# ANTLR4 output directory where all output is generated to.
gen-output

# Ignore .antlr dir itself and all its contents.
**/.antlr/**

# Ignore logs...
logs
*.log

*.local
